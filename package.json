{
  "name": "mtg-deckbuilder",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "prebuild": "node -e \"try{require('fs').rmSync('dist',{recursive:true})}catch(e){}\"",
    "build": "npm run prebuild && tsc && vite build",
    "build:api": "esbuild worker/index.ts --bundle --outfile=dist-api/worker.js --format=esm --platform=browser --target=esnext --minify",
    "preview": "vite preview",
    "db:create": "wrangler d1 create mtg-deckbuilder",
    "db:migrate": "wrangler d1 execute mtg-deckbuilder --file=./src/database/schema.sql",
    "db:migrate:local": "wrangler d1 execute mtg-deckbuilder --local --file=./src/database/schema.sql",
    "deploy:api": "wrangler deploy",
    "deploy:api:dist": "wrangler deploy --config=wrangler.deploy.toml",
    "deploy:pages": "wrangler pages deploy dist --project-name=mtg-deckbuilder",
    "deploy": "npm run build && npm run deploy:api && npm run deploy:pages"
  },
  "dependencies": {
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wrangler": "^4.66.0"
  }
}
